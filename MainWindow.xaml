<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:zd2_Romanov"
        xmlns:System="clr-namespace:System;assembly=mscorlib" x:Class="zd2_Romanov.MainWindow"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="747">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="801"/>
        </Grid.ColumnDefinitions>

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Width="265" Height="430" Margin="0,0,0,-11">
            <Menu Height="20" Width="200" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,0,0">
                <MenuItem x:Name="Load" Header="Загрузить" Click="Load_Click"/>
                <MenuItem x:Name="Save" Header="Сохранить" Click="Save_Click"/>
                <MenuItem x:Name="ExitButton" Header="Выход" Click="Exit_Click"/>
            </Menu>
            <Label Content="Название файла" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Width="200"/>
            <TextBox x:Name="TextBox_fileName" HorizontalAlignment="Left" TextWrapping="Wrap" Background="#FFE8DADA" BorderBrush="#FF203A88" Height="18" Width="205"/>
            <Label Content="Фамилия и имя" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Width="200"/>
            <TextBox x:Name="TextBox_Name" HorizontalAlignment="Left" TextWrapping="Wrap" Background="#FFE8DADA" BorderBrush="#FF203A88" Height="18" Width="205"/>
            <Label Content="Номер телефона" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Width="200"/>
            <TextBox x:Name="TextBox_Phone" HorizontalAlignment="Left" TextWrapping="Wrap" Background="#FFE8DADA" BorderBrush="#FF203A88" Height="18" Width="205"/>
            <Label Content="Индекс" VerticalAlignment="Top" HorizontalAlignment="Left" Height="26" Width="200"/>
            <TextBox x:Name="TextBox_Index" HorizontalAlignment="Left" TextWrapping="Wrap" Background="#FFE8DADA" BorderBrush="#FF203A88" Height="18" Width="205"/>


            <Button Height="20" Content="Добавить" VerticalAlignment="Top" HorizontalAlignment="Left" Click="Button_Click" Width="205"/>
            <Button Height="20" Content="Удалить выбранный элемент" VerticalAlignment="Top" HorizontalAlignment="Left" Click="Delete_Click" Width="205"/>
            <Button Height="20" Content="Удалить по индексу" VerticalAlignment="Top" HorizontalAlignment="Left" Click="DeleteIndex_Click" Width="205"/>
            <Button Height="20" Content="Поиск по фамилии и имени" VerticalAlignment="Top" HorizontalAlignment="Left" Click="Search_Click" Width="205"/>
            <Button Height="20" Content="Сброс" VerticalAlignment="Top" HorizontalAlignment="Left" Click="Reset_Click" Width="205"/>

        </StackPanel>

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Width="250" Height="300" Margin="330,0,0,0">
            <DataGrid x:Name="Grid" SelectionChanged="Grid_SelectionChanged" AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True" Height="300">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}"/>
                </DataGrid.Columns>

            </DataGrid>
        </StackPanel>


    </Grid>
</Window>